{
  "name": "outscal-jobs",
  "version": "1.0.0",
  "description": "Outscal jobs harvester — pulls growth/tech roles from 2,000+ gaming/tech company ATSes into CSV. Forked from career-ops.",
  "scripts": {
    "harvest": "node harvest.mjs",
    "doctor": "node doctor.mjs",
    "verify": "node verify-pipeline.mjs",
